--// TELEPORT BUTTON CREATOR
local added = {}

local function createTeleportButton(part)
	if added[part] then return end
	added[part] = true

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -5, 0, 30)
	btn.Text = part.Name
	btn.Parent = scroll

	btn.MouseButton1Click:Connect(function()
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			char.HumanoidRootPart.CFrame = part.CFrame + Vector3.new(0,3,0)
		end
	end)
end

--// SMART SEARCH
local function isBadgeLike(obj)
	local name = string.lower(obj.Name)

	if name:find("floppa cube") then
		return false
	end

	return (
		name:find("badge") or
		name:find("giver") or
		name:find("floppa") or
		name:find("Floppa") or
		name:find("badgegiver") or
		name:find("floppamorph") or
		name:find("Harp Floppa")
	)
end

findBtn.MouseButton1Click:Connect(function()
	scroll:ClearAllChildren()
	layout.Parent = scroll
	table.clear(added)

	-- PRIORITY FOLDERS
	local folders = {
		workspace:FindFirstChild("Floppas"),
		workspace:FindFirstChild("Badge Givers")
	}

	for _, folder in pairs(folders) do
		if folder then
			for _, obj in ipairs(folder:GetDescendants()) do
				if isBadgeLike(obj) then
					local part = obj

					if not obj:IsA("BasePart") then
						part = obj:FindFirstChildWhichIsA("BasePart", true)
					end

					if part then
						createTeleportButton(part)
					end
				end
			end
		end
	end

	-- GLOBAL SEARCH (fallback)
	for _, obj in ipairs(workspace:GetDescendants()) do
		if isBadgeLike(obj) then
			local part = obj

			if not obj:IsA("BasePart") then
				part = obj:FindFirstChildWhichIsA("BasePart")
			end

			if part then
				createTeleportButton(part)
			end
		end
	end

	task.wait()
	scroll.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
end)


--// FLY
local flying = false
flyBtn.MouseButton1Click:Connect(function()
	flying = not flying

	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")

	if flying then
		local bv = Instance.new("BodyVelocity", hrp)
		bv.MaxForce = Vector3.new(1e5,1e5,1e5)

		RunService.RenderStepped:Connect(function()
			if flying then
				bv.Velocity = workspace.CurrentCamera.CFrame.LookVector * 50
			end
		end)
	else
		if hrp:FindFirstChildOfClass("BodyVelocity") then
			hrp:FindFirstChildOfClass("BodyVelocity"):Destroy()
		end
	end
end)

--// NOCLIP
local noclip = false
noclipBtn.MouseButton1Click:Connect(function()
	noclip = not noclip
end)

RunService.Stepped:Connect(function()
	if noclip and player.Character then
		for _, v in pairs(player.Character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)

--// INFINITE JUMP
local infJump = false
infJumpBtn.MouseButton1Click:Connect(function()
	infJump = not infJump
end)

UIS.JumpRequest:Connect(function()
	if infJump and player.Character then
		player.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
	end
end)

--// REJOIN
rejoinBtn.MouseButton1Click:Connect(function()
	TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, player)
end)
