-- ESP
-- =====================
function clearESP()
    for _, v in pairs(activeBillboards) do
        pcall(function() v:Destroy() end)
    end
    for _, v in pairs(activeHighlights) do
        pcall(function() v:Destroy() end)
    end
    activeBillboards = {}
    activeHighlights = {}
end

local function applyESP(p)
    local char = p.Character; if not char then return end
    local head = char:FindFirstChild("Head"); if not head then return end
    if head:FindFirstChild("ESP_BB") then return end

    -- Billboard
    local bb = Instance.new("BillboardGui")
    bb.Name          = "ESP_BB"
    bb.Size          = UDim2.new(0, 140, 0, 52)
    bb.StudsOffset   = Vector3.new(0, 3.2, 0)
    bb.AlwaysOnTop   = true
    bb.Adornee       = head
    bb.Parent        = head

    local bg = Instance.new("Frame")
    bg.Size                   = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3       = Color3.fromRGB(8, 6, 18)
    bg.BackgroundTransparency = 0.2
    bg.BorderSizePixel        = 0
    bg.Parent                 = bb
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 5)

    -- Stroke border
    local stroke = Instance.new("UIStroke")
    stroke.Color       = Color3.fromRGB(255, 60, 60)
    stroke.Thickness   = 1
    stroke.Transparency = 0.4
    stroke.Parent      = bg

    -- Name
    local nameL = Instance.new("TextLabel")
    nameL.Size                 = UDim2.new(1, -6, 0, 18)
    nameL.Position             = UDim2.new(0, 3, 0, 2)
    nameL.BackgroundTransparency = 1
    nameL.Text                 = p.Name
    nameL.TextColor3           = Color3.fromRGB(255, 100, 100)
    nameL.Font                 = Enum.Font.GothamBold
    nameL.TextSize             = 11
    nameL.TextXAlignment       = Enum.TextXAlignment.Center
    nameL.TextStrokeTransparency = 0.4
    nameL.Parent               = bg

    -- HP label
    local hpL = Instance.new("TextLabel")
    hpL.Size                   = UDim2.new(1, -6, 0, 14)
    hpL.Position               = UDim2.new(0, 3, 0, 20)
    hpL.BackgroundTransparency = 1
    hpL.Text                   = "HP: ? / ?"
    hpL.TextColor3             = Color3.fromRGB(80, 255, 130)
    hpL.Font                   = Enum.Font.Gotham
    hpL.TextSize               = 10
    hpL.TextXAlignment         = Enum.TextXAlignment.Center
    hpL.TextStrokeTransparency = 0.5
    hpL.Parent                 = bg

    -- Distance label
    local distL = Instance.new("TextLabel")
    distL.Size                   = UDim2.new(1, -6, 0, 14)
    distL.Position               = UDim2.new(0, 3, 0, 35)
    distL.BackgroundTransparency = 1
    distL.Text                   = "Dist: ? st"
    distL.TextColor3             = Color3.fromRGB(180, 180, 255)
    distL.Font                   = Enum.Font.Gotham
    distL.TextSize               = 10
    distL.TextXAlignment         = Enum.TextXAlignment.Center
    distL.TextStrokeTransparency = 0.5
    distL.Parent                 = bg

    -- Update HP live
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        local function updateHP()
            if hpL and hpL.Parent then
                hpL.Text = "HP: "..math.floor(hum.Health).." / "..math.floor(hum.MaxHealth)
            end
        end
        updateHP()
        hum:GetPropertyChangedSignal("Health"):Connect(updateHP)
    end

    -- Update distance every frame
    RunService.Heartbeat:Connect(function()
        if distL and distL.Parent and p.Character then
            distL.Text = "Dist: "..getDistance(p).." st"
        end
    end)

    -- Highlight (chams)
    local ok, hl = pcall(function()
        local h = Instance.new("Highlight")
        h.Adornee             = char
        h.FillColor           = Color3.fromRGB(255, 60, 60)
        h.OutlineColor        = Color3.fromRGB(255, 180, 180)
        h.FillTransparency    = 0.65
        h.OutlineTransparency = 0
        h.Parent              = char
        return h
    end)

    table.insert(activeBillboards, bb)
    if ok and hl then table.insert(activeHighlights, hl) end
end

local function refreshESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and not isSameTeam(p) then
            if p.Character then applyESP(p) end
            p.CharacterAdded:Connect(function()
                task.wait(1)
                if espOn and not isSameTeam(p) then applyESP(p) end
            end)
        end
    end
end

Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function()
        task.wait(1)
        if espOn and not isSameTeam(p) then applyESP(p) end
    end)
end)

-- =====================
-- AIMBOT - HEARTBEAT
-- runs AFTER camera scripts so it wins
-- =====================
local function getBestTarget()
    local cam     = workspace.CurrentCamera
    local center  = getScreenCenter()
    local bestDist   = CONFIG.AimFOV
    local bestTarget = nil
    local bestHead3D = nil

    local myChar = localPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

    for _, p in ipairs(Players:GetPlayers()) do
        if p == localPlayer then continue end
        if isSameTeam(p) then continue end
        local char = p.Character; if not char then continue end
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local sp, head3D = headScreenPos(p)
        if not sp then continue end

        if myRoot and hasWall(myRoot.Position, head3D) then continue end

        local dist = (sp - center).Magnitude
        if dist < bestDist then
            bestDist   = dist
            bestTarget = p
            bestHead3D = head3D
        end
    end

    return bestTarget, bestHead3D
end

-- BindToRenderStep AFTER camera priority so we always win
local CAM_PRIORITY = Enum.RenderPriority.Camera.Value + 1

RunService:BindToRenderStep("NriculAimbot", CAM_PRIORITY, function()

    -- Refresh ESP when on
    if espOn then refreshESP() end

    -- Determine if we should be aiming:
    -- RightClick held OR toggle mode with U key
    local shouldAim = aimbotOn or
        UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)

    if not shouldAim then
        fovCircle.ImageColor3 = Color3.fromRGB(255, 60, 60) -- red = not locked
        return
    end

    local target, head3D = getBestTarget()
    if not target or not head3D then
        fovCircle.ImageColor3 = Color3.fromRGB(255, 60, 60)
        return
    end

    -- Locked indicator
    fovCircle.ImageColor3 = Color3.fromRGB(60, 255, 100)

    local cam     = workspace.CurrentCamera
    local desired = CFrame.lookAt(cam.CFrame.Position, head3D)

    if CONFIG.AimSmoothing <= 1 then
        -- Instant snap
        cam.CFrame = desired
    else
        -- Smooth
        local alpha = math.clamp(1 / CONFIG.AimSmoothing, 0.01, 1)
        cam.CFrame  = cam.CFrame:Lerp(desired, alpha)
    end
end)
