-- =====================
-- UTILITIES
-- =====================
local function isSameTeam(p)
    if not CONFIG.TeamCheck then return false end
    return p.Team ~= nil and p.Team == localPlayer.Team
end

local function hasWall(origin, target)
    if not CONFIG.WallCheck then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local chars = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then table.insert(chars, plr.Character) end
    end
    params.FilterDescendantsInstances = chars
    local result = workspace:Raycast(origin, target - origin, params)
    return result ~= nil
end

local function getScreenCenter()
    return workspace.CurrentCamera.ViewportSize / 2
end

local function headScreenPos(p)
    local char = p.Character
    if not char then return nil, nil end
    local head = char:FindFirstChild("Head")
    if not head then return nil, nil end
    local sp, onScreen = workspace.CurrentCamera:WorldToViewportPoint(head.Position)
    if not onScreen or sp.Z < 0 then return nil, nil end
    return Vector2.new(sp.X, sp.Y), head.Position
end

local function getDistance(p)
    local myChar = localPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return 0 end
    local theirChar = p.Character
    local theirRoot = theirChar and theirChar:FindFirstChild("HumanoidRootPart")
    if not theirRoot then return 0 end
    return math.floor((myRoot.Position - theirRoot.Position).Magnitude)
end

