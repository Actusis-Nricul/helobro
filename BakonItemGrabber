-- Draggable
local dragging = false
local dragStart
local startPos

TopBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart

		MainFrame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- =====================
-- ITEM FINDING (works for any chapter, any item)
-- =====================
local function getInteract(itemModel)

	local prompt = itemModel:FindFirstChildOfClass("ProximityPrompt", true)
	if not prompt then
		for _, d in ipairs(itemModel:GetDescendants()) do
			if d:IsA("ProximityPrompt") then
				prompt = d
				break
			end
		end
	end
	if prompt then
		return "prompt", prompt
	end


	local detector = itemModel:FindFirstChildOfClass("ClickDetector", true)
	if not detector then
		for _, d in ipairs(itemModel:GetDescendants()) do
			if d:IsA("ClickDetector") then
				detector = d
				break
			end
		end
	end
	if detector then
		return "click", detector
	end

	return nil, nil
end

local function getTargetPart(itemModel)
	if itemModel:IsA("BasePart") then
		return itemModel
	end

	local bounds = itemModel:FindFirstChild("Bounds")
	if bounds then
		if bounds:IsA("BasePart") then return bounds end
		local p = bounds:FindFirstChildWhichIsA("BasePart", true)
		if p then return p end
	end
	return itemModel.PrimaryPart or itemModel:FindFirstChildWhichIsA("BasePart", true)
end

local function findAllItems()
	local items = {}

	local objectsRoot = workspace:FindFirstChild("Objects")
	if not objectsRoot then return items end

	local mapFolder = objectsRoot:FindFirstChild("Map")
	if not mapFolder then return items end


	for _, chapterFolder in ipairs(mapFolder:GetChildren()) do
		if chapterFolder.Name:match("^Chapter%d+$") then
			local objFolder = chapterFolder:FindFirstChild("Objects")
			if objFolder then
				local utilFolder = objFolder:FindFirstChild("Util")
				if utilFolder then
					for _, itemModel in ipairs(utilFolder:GetChildren()) do
						local interactType, interactObj = getInteract(itemModel)
						if interactType then
							table.insert(items, {
								model = itemModel,
								name = itemModel.Name,
								interactType = interactType,
								interactObj = interactObj,
								chapter = chapterFolder.Name,
							})
						end
					end
				end
			end
		end
	end

	return items
end

-- Item Refresh Loop
while task.wait(6) do
	for _, child in ipairs(ScrollingFrame:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end

	local items = findAllItems()

	for _, item in ipairs(items) do
		local ItemFrame = Instance.new("TextButton")
		ItemFrame.Parent = ScrollingFrame
		ItemFrame.BackgroundColor3 = Color3.fromRGB(51, 51, 40)
		ItemFrame.BackgroundTransparency = 0.95
		ItemFrame.Size = UDim2.new(0, 100, 0, 100)
		ItemFrame.Text = item.name .. "\n(" .. item.chapter .. ")"
		ItemFrame.TextScaled = true
		ItemFrame.TextWrapped = true
		ItemFrame.TextColor3 = Color3.new(1, 1, 1)

		ItemFrame.MouseButton1Click:Connect(function()
			local character = LocalPlayer.Character
			local hrp = character and character:FindFirstChild("HumanoidRootPart")
			if not hrp then return end

			local targetPart = getTargetPart(item.model)
			if not targetPart then
				warn("Couldn't find part for", item.name)
				return
			end

			local oldPos = hrp.CFrame
			hrp.CFrame = targetPart.CFrame + Vector3.new(0, 3, 0)

			task.wait(0.15)

			if item.interactType == "prompt" then
				pcall(function()
					fireproximityprompt(item.interactObj)
				end)
			elseif item.interactType == "click" then
				pcall(function()
					fireclickdetector(item.interactObj)
				end)
			end

			task.wait(0.25)

			hrp.CFrame = oldPos
		end)

		ScrollingFrame.CanvasSize = UDim2.new(
			0, 0, 0,
			UIGridLayout.AbsoluteContentSize.Y + 10
		)
	end
end
