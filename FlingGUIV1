local player = game.Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")

local running = true

-- 🎚️ SETTINGS
local POWER = 150
local UPWARD_MULTIPLIER = 0.5 -- 0 to 1

local flingForward = true
local verticalUp = true

-- 🚀 FLING FUNCTION
local function fling()
	local character = player.Character
	if not character then return end

	local hrp = character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	local lookVector = hrp.CFrame.LookVector

	-- 🔁 forward / backward
	local directionVector = flingForward and lookVector or -lookVector

	-- 🎯 angle clamp
	local angle = math.clamp(UPWARD_MULTIPLIER, 0, 1)

	-- 🧭 horizontal
	local horizontal = Vector3.new(directionVector.X, 0, directionVector.Z)
	if horizontal.Magnitude == 0 then
		horizontal = Vector3.new(0,0,-1)
	end
	horizontal = horizontal.Unit

	-- ⬆️⬇️ vertical toggle
	local verticalDirection = verticalUp and Vector3.new(0,1,0) or Vector3.new(0,-1,0)

	-- 🎯 final direction
	local direction = (horizontal * (1 - angle) + verticalDirection * angle).Unit

	local bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.Velocity = direction * POWER
	bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
	bodyVelocity.Parent = hrp

	game.Debris:AddItem(bodyVelocity, 0.25)
end

