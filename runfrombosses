		bg.Parent = hrp
	else
		flyBtn.Text = "Fly: OFF"
		flyBtn.BackgroundColor3 = Color3.fromRGB(60,60,60)

		if bv then bv:Destroy() end
		if bg then bg:Destroy() end
	end
end)

