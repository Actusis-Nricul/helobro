-- 🎮 Movement
local ctrl = {f=0,b=0,l=0,r=0,u=0,d=0}

UIS.InputBegan:Connect(function(i,g)
	if g then return end
	if i.KeyCode == Enum.KeyCode.W then ctrl.f=1 end
	if i.KeyCode == Enum.KeyCode.S then ctrl.b=-1 end
	if i.KeyCode == Enum.KeyCode.A then ctrl.l=-1 end
	if i.KeyCode == Enum.KeyCode.D then ctrl.r=1 end
	if i.KeyCode == Enum.KeyCode.Space then ctrl.u=1 end
	if i.KeyCode == Enum.KeyCode.LeftControl then ctrl.d=-1 end
end)

UIS.InputEnded:Connect(function(i)
	if i.KeyCode == Enum.KeyCode.W then ctrl.f=0 end
	if i.KeyCode == Enum.KeyCode.S then ctrl.b=0 end
	if i.KeyCode == Enum.KeyCode.A then ctrl.l=0 end
	if i.KeyCode == Enum.KeyCode.D then ctrl.r=0 end
	if i.KeyCode == Enum.KeyCode.Space then ctrl.u=0 end
	if i.KeyCode == Enum.KeyCode.LeftControl then ctrl.d=0 end
end)

-- 🔁 Loop
RunService.RenderStepped:Connect(function()
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	-- fly
	if flying and bv and bg then
		local cam = workspace.CurrentCamera
		local move = (cam.CFrame.LookVector*(ctrl.f+ctrl.b)
			+ cam.CFrame.RightVector*(ctrl.r+ctrl.l)
			+ Vector3.new(0, ctrl.u+ctrl.d, 0))

		bv.Velocity = move * flySpeed
		bg.CFrame = cam.CFrame
	end

	-- noclip
	if noclip then
		for _,v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	else
		for _,v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = true
			end
		end
	end
end)

-- 📂 Get checkpoints
local world1Folder = workspace:WaitForChild("Worlds"):WaitForChild("1"):WaitForChild("Checkpoints")
local world2Folder = workspace:WaitForChild("Worlds"):WaitForChild("2"):WaitForChild("Checkpoints")

local function getSorted(folder)
	local list = {}
	for _, v in pairs(folder:GetChildren()) do
		table.insert(list, v)
	end

	table.sort(list, function(a, b)
		return tonumber(a.Name) < tonumber(b.Name)
	end)

	return list
end

-- 🧱 Dropdown creator
local function createDropdown(name, yPos, folder)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(0.9, 0, 0, 30)
	container.Position = UDim2.new(0.05, 0, 0, yPos)
	container.BackgroundColor3 = Color3.fromRGB(50,50,50)
	container.Parent = main
	container.ZIndex = 1
	Instance.new("UICorner", container)

	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1, 0, 1, 0)
	button.Text = name .. " ▼"
	button.BackgroundTransparency = 1
	button.TextColor3 = Color3.new(1,1,1)
	button.Parent = container
	button.ZIndex = 2

	local listFrame

	button.MouseButton1Click:Connect(function()

		-- 🔥 close previous dropdown
		if currentDropdown and currentDropdown ~= container then
			local old = currentDropdown:FindFirstChild("DropdownList")
			if old then old:Destroy() end
		end

		-- toggle this one
		if listFrame then
			listFrame:Destroy()
			listFrame = nil
			currentDropdown = nil
			return
		end

		currentDropdown = container

		-- 📜 scrolling dropdown
		listFrame = Instance.new("ScrollingFrame")
		listFrame.Name = "DropdownList"
		listFrame.Size = UDim2.new(1, 0, 0, 100)
		listFrame.Position = UDim2.new(0, 0, 1, 2)
		listFrame.BackgroundColor3 = Color3.fromRGB(35,35,35)
		listFrame.ScrollBarThickness = 4
		listFrame.CanvasSize = UDim2.new(0,0,0,0)
		listFrame.Parent = container
		listFrame.ZIndex = 10
		Instance.new("UICorner", listFrame)

		local layout = Instance.new("UIListLayout", listFrame)
		layout.Padding = UDim.new(0, 3)

		layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			listFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y)
		end)

		for _, checkpoint in pairs(getSorted(folder)) do
			local item = Instance.new("TextButton")
			item.Size = UDim2.new(1, -4, 0, 24)
			item.Text = "Checkpoint " .. checkpoint.Name
			item.BackgroundColor3 = Color3.fromRGB(60,60,60)
			item.TextColor3 = Color3.new(1,1,1)
			item.Parent = listFrame
			item.ZIndex = 11
			Instance.new("UICorner", item)

			item.MouseButton1Click:Connect(function()
	local char = player.Character
	if char and char:FindFirstChild("HumanoidRootPart") then
		char.HumanoidRootPart.CFrame = checkpoint.CFrame + Vector3.new(0,5,0)
				end
			end)
		end
	end)
end

local currentDropdown = nil

-- 📍 Create dropdowns
createDropdown("World 1 Checkpoints", 160, world1Folder)
createDropdown("World 2 Checkpoints", 250, world2Folder)

