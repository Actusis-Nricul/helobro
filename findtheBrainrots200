local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

local function getRoot()
    local char = localPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

task.spawn(function()
    while true do
        local root = getRoot()
        if root then
            local Brainrots = workspace:FindFirstChild("Brainrots")
            if Brainrots then
                for _, Brainrots in ipairs(Brainrots:GetChildren()) do
                    
                    local ti = Brainrots:FindFirstChild("TouchInterest")
                    if ti then
                     
                       
                        local part = Brainrots:IsA("BasePart") and Brainrots
                            or Brainrots:FindFirstChildWhichIsA("BasePart", true)
                        if part then
                            pcall(function()
                                firetouchinterest(root, part, 0)
                                firetouchinterest(root, part, 1)
                            end)
                        end
                    end
                end
            end
        end
        task.wait()
    end
end)
