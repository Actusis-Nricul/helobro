speedBox.ClearTextOnFocus = false
speedBox.Parent = frame

Instance.new("UICorner", speedBox)

---------------------------------------------------
-- CONSTANT SPEED BUTTON
---------------------------------------------------

local speedBtn = Instance.new("TextButton")
speedBtn.Size = UDim2.new(0,100,0,40)
speedBtn.Position = UDim2.new(0,210,0,250)

speedBtn.BackgroundColor3 = Color3.fromRGB(70,120,70)
speedBtn.TextColor3 = Color3.new(1,1,1)

speedBtn.Font = Enum.Font.GothamBold
speedBtn.TextSize = 18
speedBtn.Text = "Speed OFF"

speedBtn.Parent = frame

Instance.new("UICorner", speedBtn)

speedBtn.MouseButton1Click:Connect(function()

	constantSpeed = not constantSpeed

	if constantSpeed then

		local value = tonumber(speedBox.Text)

		if value then
			walkSpeedValue = value
		end

		speedBtn.Text = "Speed ON"

	else

		speedBtn.Text = "Speed OFF"
    end
end)

---------------------------------------------------
-- CONSTANT SPEED LOOP
---------------------------------------------------

RunService.RenderStepped:Connect(function()

	if constantSpeed then

		local char = player.Character

		if char then

			local hum = char:FindFirstChildOfClass("Humanoid")

			if hum then

				-- constantly apply walkspeed only
				hum.WalkSpeed = walkSpeedValue
			end
		end
	end
end)

