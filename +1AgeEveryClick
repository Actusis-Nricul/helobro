---------------------------------------------------
-- BUTTON MAKER
---------------------------------------------------

local function makeButton(text,y)

	local btn = Instance.new("TextButton")

	btn.Size = UDim2.new(0,300,0,40)
	btn.Position = UDim2.new(0,20,0,y)

	btn.BackgroundColor3 = Color3.fromRGB(45,45,45)

	btn.TextColor3 = Color3.new(1,1,1)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 18

	btn.Text = text
	btn.Parent = frame

	Instance.new("UICorner", btn)

	return btn
end

---------------------------------------------------
-- VARIABLES
---------------------------------------------------

local autoClick = false
local autoRebirth = false
local infiniteJump = false
local constantSpeed = false

local walkSpeedValue = 16

---------------------------------------------------
-- AUTO CLICK
---------------------------------------------------

local clickBtn = makeButton("Auto Click: OFF",60)

clickBtn.MouseButton1Click:Connect(function()

	autoClick = not autoClick

	if autoClick then
		clickBtn.Text = "Auto Click: ON"
	else
		clickBtn.Text = "Auto Click: OFF"
	end
end)

RunService.RenderStepped:Connect(function()

	if autoClick then

		ReplicatedStorage.MouseClicked:FireServer()

        task.wait()
	end
end)

---------------------------------------------------
-- AUTO REBIRTH
---------------------------------------------------

local rebirthBtn = makeButton("Auto Rebirth: OFF",120)

rebirthBtn.MouseButton1Click:Connect(function()

	autoRebirth = not autoRebirth

	if autoRebirth then

		rebirthBtn.Text = "Auto Rebirth: ON"

		task.spawn(function()

			while autoRebirth do

				ReplicatedStorage.RebirthEvent:FireServer()

				task.wait(4)
			end
		end)

	else
		rebirthBtn.Text = "Auto Rebirth: OFF"
	end
end)

---------------------------------------------------
-- INFINITE JUMP
---------------------------------------------------

local infJumpBtn = makeButton("Infinite Jump: OFF",180)

infJumpBtn.MouseButton1Click:Connect(function()

	infiniteJump = not infiniteJump

	if infiniteJump then
		infJumpBtn.Text = "Infinite Jump: ON"
	else
		infJumpBtn.Text = "Infinite Jump: OFF"
	end
end)

UIS.JumpRequest:Connect(function()

	if infiniteJump then

		local char = player.Character

		if char then

			local hum = char:FindFirstChildOfClass("Humanoid")

			if hum then
				hum:ChangeState(Enum.HumanoidStateType.Jumping)
			end
		end
	end
end)

