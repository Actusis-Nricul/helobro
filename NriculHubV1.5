local op = tabFrames["Others"]
local activeHighlights, activeBillboards = {}, {}
local espAllActive, hlAllActive = false, false

local function clearESP()
    for _, v in pairs(activeBillboards) do pcall(function() v:Destroy() end) end
    for _, v in pairs(activeHighlights) do pcall(function() v:Destroy() end) end
    activeBillboards = {}; activeHighlights = {}
end

local function applyESP(p)
    local char = p.Character; if not char then return end
    local head = char:FindFirstChild("Head"); if not head then return end
    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.new(0, 120, 0, 32); bb.StudsOffset = Vector3.new(0, 3.5, 0)
    bb.AlwaysOnTop = true; bb.Adornee = head; bb.Parent = head
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0); bg.BackgroundColor3 = Color3.fromRGB(15, 10, 30)
    bg.BackgroundTransparency = 0.3; bg.BorderSizePixel = 0; bg.Parent = bb
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 4)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, 0, 1, 0); lbl.BackgroundTransparency = 1
    lbl.Text = p.Name; lbl.TextColor3 = Color3.fromRGB(180, 130, 255)
    lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 12
    lbl.TextStrokeTransparency = 0.5; lbl.Parent = bg
    table.insert(activeBillboards, bb)
end

local function applyHighlight(p)
    local char = p.Character; if not char then return end
    local ok, hl = pcall(function()
        local h = Instance.new("Highlight")
        h.Adornee = char; h.FillColor = Color3.fromRGB(120, 80, 255)
        h.OutlineColor = Color3.fromRGB(200, 160, 255)
        h.FillTransparency = 0.5; h.OutlineTransparency = 0; h.Parent = char
        return h
    end)
    if ok and hl then
        table.insert(activeHighlights, hl)
    else
        local sel = Instance.new("SelectionBox")
        sel.Adornee = char; sel.Color3 = Color3.fromRGB(120, 80, 255)
        sel.LineThickness = 0.06; sel.SurfaceTransparency = 0.75
        sel.SurfaceColor3 = Color3.fromRGB(100, 60, 255); sel.Parent = char
        table.insert(activeHighlights, sel)
    end
end

