-- Freecam: WASD moves cam, character stops being controlled
createToggle(pl, "Freecam [WASD, F off]", BTN_BASE, function(on)
    if connections.freecam then connections.freecam:Disconnect(); connections.freecam = nil end
    if connections.freecamKey then connections.freecamKey:Disconnect(); connections.freecamKey = nil end

    local cam = workspace.CurrentCamera
    local hum = getHum()

    if on then
        -- Detach character controls
        if hum then
            hum.WalkSpeed = 0
            hum.JumpPower = 0
        end
        cam.CameraType = Enum.CameraType.Scriptable
        local camCF = cam.CFrame

        connections.freecam = RunService.Heartbeat:Connect(function()
            local spd = flySpeed * 0.015
            local moved = false
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then camCF = camCF * CFrame.new(0, 0, -spd); moved = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then camCF = camCF * CFrame.new(0, 0, spd); moved = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then camCF = camCF * CFrame.new(-spd, 0, 0); moved = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then camCF = camCF * CFrame.new(spd, 0, 0); moved = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then camCF = camCF * CFrame.new(0, spd, 0); moved = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then camCF = camCF * CFrame.new(0, -spd, 0); moved = true end
            cam.CFrame = camCF
        end)

        -- F key to exit
        connections.freecamKey = UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if input.KeyCode == Enum.KeyCode.F then
                -- restore
                cam.CameraType = Enum.CameraType.Custom
                if connections.freecam then connections.freecam:Disconnect(); connections.freecam = nil end
                local h = getHum()
                if h then
                    h.WalkSpeed = 16
                    h.JumpPower = 50
                end
                toggleStates["Freecam [WASD, F off]"] = false
                if connections.freecamKey then connections.freecamKey:Disconnect(); connections.freecamKey = nil end
                notify("Freecam", "Disabled", 2)
            end
        end)

        notify("Freecam", "WASD to move, Space/Shift up/down, F to exit", 5)
    else
        cam.CameraType = Enum.CameraType.Custom
        local h = getHum()
        if h then h.WalkSpeed = 16; h.JumpPower = 50 end
    end
end)

