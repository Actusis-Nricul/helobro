            vps:Button2Up(Vector2.zero, workspace.CurrentCamera.CFrame)
        end)
    end
end)

createToggle(ms, "Auto Collect Nearby", BTN_BASE, function(on)
    if connections.collect then connections.collect:Disconnect(); connections.collect = nil end
    if on then
        connections.collect = RunService.Heartbeat:Connect(function()
            local root = getRoot(); if not root then return end
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and (obj.Position-root.Position).Magnitude < 15 then
                    pcall(function() firetouchinterest(root, obj, 0) end)
                end
            end
        end)
    end
end)

createToggle(ms, "Hide Top Bar", BTN_BASE, function(on)
    game:GetService("StarterGui"):SetCore("TopbarEnabled", not on)
end)

createToggle(ms, "Auto Jump", BTN_BASE, function(on)
    localPlayer.AutoJumpEnabled = on
end)

createToggle(ms, "Disable Animations", BTN_BASE, function(on)
    local char = localPlayer.Character; if not char then return end
    local anim = char:FindFirstChild("Animate")
    if anim then anim.Disabled = on end
end)

createToggle(ms, "Third Person Lock", BTN_BASE, function(on)
    localPlayer.CameraMinZoomDistance = on and 10 or 0.5
    localPlayer.CameraMaxZoomDistance = on and 10 or 400
end)

createToggle(ms, "Spin Camera", BTN_BASE, function(on)
    if connections.spincam then connections.spincam:Disconnect(); connections.spincam = nil end
    local cam = workspace.CurrentCamera
    if on then
        local h = 0
        connections.spincam = RunService.Heartbeat:Connect(function()
            h += 0.02
            local root = getRoot(); if not root then return end
            cam.CFrame = CFrame.new(
                root.Position + Vector3.new(math.sin(h)*20, 10, math.cos(h)*20),
                root.Position
            )
        end)
    else
        cam.CameraType = Enum.CameraType.Custom
    end
end)

createButton(ms, "Max Volume", BTN_BASE, function()
    for _, s in ipairs(workspace:GetDescendants()) do if s:IsA("Sound") then s.Volume=10 end end
    notify("Audio", "Maxed", 3)
end)

createButton(ms, "Mute All Sounds", BTN_BASE, function()
    for _, s in ipairs(workspace:GetDescendants()) do if s:IsA("Sound") then s.Volume=0 end end
    notify("Audio", "Muted", 3)
end)

createButton(ms, "Stop All Sounds", BTN_BASE, function()
    for _, s in ipairs(workspace:GetDescendants()) do
        if s:IsA("Sound") and s.Playing then s:Stop() end
    end
    notify("Audio", "Stopped", 3)
end)

createButton(ms, "Instance Count", BTN_BASE, function()
    notify("Workspace", "Instances: "..#workspace:GetDescendants(), 4)
end)

