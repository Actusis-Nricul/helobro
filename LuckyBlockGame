-- =====================
-- BUTTON FACTORY
-- =====================
local BTN_OFF = Color3.fromRGB(50, 50, 65)
local BTN_ON  = Color3.fromRGB(25, 110, 60)
local BTN_TXT = Color3.fromRGB(220, 220, 235)

local btnY = 40

local function makeBtn(labelOff, onToggle)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 36)
    btn.Position = UDim2.new(0, 10, 0, btnY)
    btn.BackgroundColor3 = BTN_OFF
    btn.Text = labelOff .. ": OFF"
    btn.TextColor3 = BTN_TXT
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 15
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.TextScaled = false
    btn.Parent = frame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btnY = btnY + 42

    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.BackgroundColor3 = state and BTN_ON or BTN_OFF
        btn.Text = labelOff .. ": " .. (state and "ON" or "OFF")
        onToggle(state)
    end)

    return btn
end

-- Resize frame after all buttons built
local function finalizeFrame()
    frame.Size = UDim2.new(0, 320, 0, btnY + 12)
end

