-- =====================
-- INFINITE LUCK
-- Fires DoorEvent with value going 0.1 -> 50000
-- Resets to 0.1 each time toggled on
-- =====================
local infiniteLuck = false
makeBtn("Infinite Luck", function(on)
    infiniteLuck = on
    if on then
        task.spawn(function()
            local ev = getRemote("DoorEvent")
            if not ev then return end
            local val = 10
            while infiniteLuck do
                ev:FireServer(val, "add")
                val = math.round((val + 10) * 100) / 100 -- avoid float drift
                if val > 7555 then
                    val = 10 -- restart from 1 when reaching 50000
                end
                task.wait(0.4)
            end
            -- reset counter when toggled off so next ON starts fresh
        end)
    end
end)

