-- =====================
-- SCAN RICHEST GARDEN
-- =====================
local function scanGardens()
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return end

    local bestCount = 0
    local bestCF    = nil
    local bestName  = "None"

    for _, plot in ipairs(gardens:GetChildren()) do
        local plants = plot:FindFirstChild("Plants")
        if not plants then continue end

        local count = 0
        for _, plant in ipairs(plants:GetChildren()) do
            -- count Fruits folder children
            local fruits = plant:FindFirstChild("Fruits")
            if fruits then
                for _, f in ipairs(fruits:GetChildren()) do
                    count = count + 1
                    -- each fruit model may have numbered sub-parts
                    count = count + #f:GetChildren() - 1
                end
            end
            -- count loose numbered parts directly under plant
            for _, child in ipairs(plant:GetChildren()) do
                if tonumber(child.Name) then count = count + 1 end
            end
        end

        if count > bestCount then
            bestCount = count
            bestName  = plot.Name
            local ref = plot:FindFirstChildWhichIsA("BasePart", true)
            if ref then bestCF = ref.CFrame + Vector3.new(0, 5, 0) end
        end
    end

    richestGardenCF  = bestCF
    richestPlotName  = bestName .. " (" .. bestCount .. " fruits)"
end

task.spawn(function()
    while true do
        scanGardens()
        task.wait(180) -- refresh every 3 minutes
    end
end)

-- =====================
-- STEAL LOGIC
-- =====================
local function stealFromPlant(plant)
    local harvestPart = plant:FindFirstChild("HarvestPart")
    if not harvestPart then return end
    local stealPrompt = harvestPart:FindFirstChild("StealPrompt")
    if not stealPrompt or not stealPrompt:IsA("ProximityPrompt") then return end
    local root = getRoot(); if not root then return end
    root.CFrame = harvestPart.CFrame + Vector3.new(0, 3, 0)
    task.wait(0.08)
    pcall(function() fireproximityprompt(stealPrompt) end)
    task.wait(0.08)
end

local function stealFromPlot(plot)
    local plants = plot:FindFirstChild("Plants")
    if not plants then return end
    for _, plant in ipairs(plants:GetChildren()) do
        if not stealActive then break end
        stealFromPlant(plant)
    end
end

