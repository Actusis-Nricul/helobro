                if isNight() then
                    stealLabel.Text      = "Stealing... (" .. os.date("%H:%M") .. ")"
                    stealLabel.TextColor3 = Color3.fromRGB(80,255,130)

                    local gardens = workspace:FindFirstChild("Gardens")
                    if gardens then
                        for _, plot in ipairs(gardens:GetChildren()) do
                            if not stealActive then break end
                            if plot.Name == ("Plot" .. selectedFieldNum) then continue end
                            stealFromPlot(plot)
                        end
                    end

                    -- return to own field
                    tpToField(selectedFieldNum)
                    stealLabel.Text      = "Pass done. Next in 10s..."
                    stealLabel.TextColor3 = Color3.fromRGB(160,230,160)
                    task.wait(10)
                else
                    stealLabel.Text      = "Make sure its Night"
                    stealLabel.TextColor3 = Color3.fromRGB(200,180,80)
                    task.wait(5)
                end
            end
            stealLabel.Text      = "Auto Steal: OFF"
            stealLabel.TextColor3 = Color3.fromRGB(180,180,180)
        end)
    end
end)

