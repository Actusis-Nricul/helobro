-- build the buffer payload for a fruit/seed name
-- format: "g\000" + <1-byte length> + <name>
local function makeSeedBuffer(name)
    local prefix = "g\000"
    local lenByte = string.char(#name)
    return buffer.fromstring(prefix .. lenByte .. name)
end

