-- =====================
-- BIG SIZE (x10)
-- =====================
local bigSize = false
local originalSizes = {}
local originalCFrames = {}

makeBtn("Big Size (x10)", "Big Size (x10)", function(on)
    bigSize = on
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    if on then
        -- Save original sizes and scale x10
        originalSizes = {}
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                originalSizes[part] = part.Size
                part.Size = part.Size * 10
            end
        end
        -- Also scale HipHeight so player doesn't sink into ground
        hum:SetAttribute("OrigHipHeight", hum.HipHeight)
        hum.HipHeight = hum.HipHeight * 10
    else
        -- Restore original sizes
        for part, size in pairs(originalSizes) do
            if part and part.Parent then
                part.Size = size
            end
        end
        originalSizes = {}
        -- Restore HipHeight
        local orig = hum:GetAttribute("OrigHipHeight")
        hum.HipHeight = orig or 0
    end
end)

