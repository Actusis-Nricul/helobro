local tycoonNames = {
    "Light", "Death", "Fire", "Wind",
    "Poison", "Ice", "Nature", "Lightning"
}

local skipButtons = {
    ["2x Cash"]            = true,
    ["3x Cash"]            = true,
    ["Auto Collect"]       = true,
    ["Forcefield"]         = true,
    ["Magic Carpet"]       = true,
    ["GravityCoil"]        = true,
    ["SpeedCoil"]          = true,
    ["Start Tycoon"]       = true,
    ["War Pack"]           = true,
    ["Gun Pack"]           = true,
    ["Rainbow Upgrader 1"] = true,
    ["Rainbow Upgrader 2"] = true,
    ["Rainbow Upgrader 3"] = true,
}

local function getRoot()
    local char = localPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHum()
    local char = localPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

-- Fire ALL BaseParts deeply, skip blacklisted names
local function fireTouchesInModel(model, root)
    for _, obj in ipairs(model:GetDescendants()) do
        if skipButtons[obj.Name] then continue end
        if obj:IsA("BasePart") then
            pcall(function()
                firetouchinterest(root, obj, 0)
                firetouchinterest(root, obj, 1)
            end)
        end
    end
end

-- Get the Buttons folder for a tycoon
-- Tries workspace.Tycoons.<Name> and workspace.Tycoons.Tycoons.<Name>
local function getTycoonButtonsFolder(tycoonName)
    local tycoons = workspace:FindFirstChild("Tycoons")
    if not tycoons then return nil end

    -- Try direct child first
    local direct = tycoons:FindFirstChild(tycoonName)
    if direct then
        return direct:FindFirstChild("Buttons") or direct
    end

    -- Try nested Tycoons folder
    local inner = tycoons:FindFirstChild("Tycoons")
    if inner then
        local nested = inner:FindFirstChild(tycoonName)
        if nested then
            return nested:FindFirstChild("Buttons") or nested
        end
    end

    return nil
end

-- Get the Giver part for a tycoon, tries multiple path variants
local function getGiverPart(tycoonName)
    local tycoons = workspace:FindFirstChild("Tycoons")
    if not tycoons then return nil end

    local function tryGet(parent)
        if not parent then return nil end
        local t = parent:FindFirstChild(tycoonName)
        if not t then return nil end
        local ess = t:FindFirstChild("Essentials")
        if ess then
            -- Try Giver as a Part directly
            local giver = ess:FindFirstChild("Giver")
            if giver and giver:IsA("BasePart") then return giver end
            -- Giver might be a Model containing a Part
            if giver then
                for _, v in ipairs(giver:GetDescendants()) do
                    if v:IsA("BasePart") then return v end
                end
            end
        end
        -- Fallback: search entire tycoon for something called Giver
        for _, v in ipairs(t:GetDescendants()) do
            if v.Name == "Giver" and v:IsA("BasePart") then return v end
        end
        return nil
    end

    -- Try workspace.Tycoons.<Name>
    local result = tryGet(tycoons)
    if result then return result end

    -- Try workspace.Tycoons.Tycoons.<Name>
    local inner = tycoons:FindFirstChild("Tycoons")
    result = tryGet(inner)
    return result
end

-- =====================
-- FIRE ALL TYCOON BUTTONS
-- =====================
createSectionLabel("  Tycoon Buttons")

createToggle("Fire All Tycoon Buttons", Color3.fromRGB(26, 30, 55), function(on)
    if connections.touchLoop then
        task.cancel(connections.touchLoop)
        connections.touchLoop = nil
    end
    if on then
        connections.touchLoop = task.spawn(function()
            while toggleStates["Fire All Tycoon Buttons"] do
                local root = getRoot()
                if root then
                    for _, tycoonName in ipairs(tycoonNames) do
                        local folder = getTycoonButtonsFolder(tycoonName)
                        if folder then
                            fireTouchesInModel(folder, root)
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    end
end)

-- Per-tycoon
createSectionLabel("  Per Tycoon")

for _, tycoonName in ipairs(tycoonNames) do
    local label = tycoonName .. " Tycoon"
    createToggle(label, Color3.fromRGB(22, 26, 46), function(on)
        local key = "tycoon_" .. tycoonName
        if connections[key] then
            task.cancel(connections[key])
            connections[key] = nil
        end
        if on then
            connections[key] = task.spawn(function()
                while toggleStates[label] do
                    local root = getRoot()
                    if root then
                        local folder = getTycoonButtonsFolder(tycoonName)
                        if folder then
                            fireTouchesInModel(folder, root)
                        end
                    end
                    task.wait(0.5)
                end
            end)
        end
    end)
end

