-- =====================
-- GIVER TELEPORT
-- Teleports to each tycoon's Giver and fires its touch
-- every 0.3s while toggled on
-- =====================
createSectionLabel("  Giver Farm")

-- Master toggle: all givers at once
createToggle("All Givers", Color3.fromRGB(22, 40, 28), function(on)
    if connections.allGivers then
        task.cancel(connections.allGivers)
        connections.allGivers = nil
    end
    if on then
        connections.allGivers = task.spawn(function()
            while toggleStates["All Givers"] do
                local root = getRoot()
                if root then
                    for _, tycoonName in ipairs(tycoonNames) do
                        local giver = getGiverPart(tycoonName)
                        if giver then
                            -- move root onto the giver
                            root.CFrame = giver.CFrame + Vector3.new(0, 3, 0)
                            -- fire touch
                            pcall(function()
                                firetouchinterest(root, giver, 0)
                                firetouchinterest(root, giver, 1)
                            end)
                            task.wait(0.1)
                        end
                    end
                end
                task.wait(0.3)
            end
        end)
    end
end)

-- Individual per-tycoon giver toggles
for _, tycoonName in ipairs(tycoonNames) do
    local label = "Giver: " .. tycoonName
    createToggle(label, Color3.fromRGB(20, 36, 26), function(on)
        local key = "giver_" .. tycoonName
        if connections[key] then
            task.cancel(connections[key])
            connections[key] = nil
        end
        if on then
            connections[key] = task.spawn(function()
                while toggleStates[label] do
                    local root = getRoot()
                    if root then
                        local giver = getGiverPart(tycoonName)
                        if giver then
                            root.CFrame = giver.CFrame + Vector3.new(0, 3, 0)
                            pcall(function()
                                firetouchinterest(root, giver, 0)
                                firetouchinterest(root, giver, 1)
                            end)
                        end
                    end
                    task.wait(0.3)
                end
            end)
        end
    end)
end

