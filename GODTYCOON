local BTN_BASE  = Color3.fromRGB(26, 26, 40)
local BTN_HOVER = Color3.fromRGB(38, 38, 58)
local GREEN_ON  = Color3.fromRGB(28, 100, 55)
local toggleStates = {}
local connections  = {}

local function createToggle(label, color, callback)
    color = color or BTN_BASE
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -16, 0, 34)
    btn.BackgroundColor3 = color
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Parent = scrollFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 7)

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 8, 0, 8)
    dot.Position = UDim2.new(0, 10, 0.5, -4)
    dot.BackgroundColor3 = Color3.fromRGB(70, 70, 100)
    dot.BorderSizePixel = 0
    dot.Parent = btn
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -28, 1, 0)
    lbl.Position = UDim2.new(0, 24, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(200, 200, 220)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = btn

    toggleStates[label] = false
    btn.MouseButton1Click:Connect(function()
        toggleStates[label] = not toggleStates[label]
        local on = toggleStates[label]
        btn.BackgroundColor3 = on and GREEN_ON or color
        dot.BackgroundColor3 = on and Color3.fromRGB(80, 255, 130) or Color3.fromRGB(70, 70, 100)
        lbl.TextColor3 = on and Color3.new(1, 1, 1) or Color3.fromRGB(200, 200, 220)
        callback(on)
    end)
    btn.MouseEnter:Connect(function()
        if not toggleStates[label] then btn.BackgroundColor3 = BTN_HOVER end
    end)
    btn.MouseLeave:Connect(function()
        if not toggleStates[label] then btn.BackgroundColor3 = color end
    end)
    return btn
end

