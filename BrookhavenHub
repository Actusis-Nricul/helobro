local function clearESP()
    for _, v in pairs(espObjects) do
        for _, obj in pairs(v) do pcall(function() obj:Destroy() end) end
    end
    espObjects = {}
end

local function getESPColor() return state.espColor end

local function updateESP()
    clearESP()
    if not state.espAll then return end

    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        local char = p.Character
        if not char then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        espObjects[p] = {}

        -- BOX
        if state.espBoxes then
            local box = Instance.new("BoxHandleAdornment")
            box.Adornee     = root
            box.Size        = Vector3.new(4, 6, 2)
            box.Color3      = getESPColor()
            box.AlwaysOnTop = true
            box.Transparency= 0.3
            box.Parent      = root
            table.insert(espObjects[p], box)
        end

        -- CHAMS
        if state.espChams then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") or part:IsA("MeshPart") then
                    local box2 = Instance.new("BoxHandleAdornment")
                    box2.Adornee     = part
                    box2.Size        = part.Size + Vector3.new(0.05,0.05,0.05)
                    box2.Color3      = getESPColor()
                    box2.AlwaysOnTop = true
                    box2.Transparency= 0.4
                    box2.Parent      = part
                    table.insert(espObjects[p], box2)
                end
            end
        end

        -- TRACER (line from bottom of screen to player)
        if state.espTracers then
            local line = Instance.new("LineHandleAdornment")
            line.Adornee     = root
            line.Length      = 0
            line.Color3      = getESPColor()
            line.AlwaysOnTop = true
            line.Thickness   = 2
            line.Parent      = root
            table.insert(espObjects[p], line)
        end
    end
end

