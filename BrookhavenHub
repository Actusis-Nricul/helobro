}
local tabPages   = {}
local tabButtons = {}
local activeTab  = nil

local function switchTab(name)
    for _, t in ipairs(tabs) do
        local page = tabPages[t.name]
        local btn  = tabButtons[t.name]
        if t.name == name then
            page.Visible = true
            tween(btn, {BackgroundColor3=THEME.TAB_ACTIVE}, 0.15)
            btn.TextColor3 = THEME.TEXT
        else
            page.Visible = false
            tween(btn, {BackgroundColor3=THEME.TAB_IDLE}, 0.15)
            btn.TextColor3 = THEME.SUBTEXT
        end
    end
    activeTab = name
end

