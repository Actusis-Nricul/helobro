-- Infinite Jump logic
local function hookInfJump()
    local hum = getHum()
    if not hum then return end
    hum.StateChanged:Connect(function(_, new)
        if state.infJump and new == Enum.HumanoidStateType.Landed then
            hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        end
    end)
end
hookInfJump()
player.CharacterAdded:Connect(function() task.wait(0.2); hookInfJump() end)
UserInputService.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if inp.KeyCode == Enum.KeyCode.Space and state.infJump then
        local hum = getHum()
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
            hum.Jump = true
        end
    end
end)

makeSeparator(movPage, "Fly")
makeInput(movPage, "Fly Speed", "40", function(v)
    local n = tonumber(v)
    if n then state.flySpeed = n end
end)

makeToggle(movPage, "Fly", function(on)
    state.fly = on

    if flyConn then flyConn:Disconnect(); flyConn = nil end
    if flyBV   then flyBV:Destroy();   flyBV   = nil end
    if flyBG   then flyBG:Destroy();   flyBG   = nil end

    if not on then
        local hum = getHum()
        if hum then hum.PlatformStand = false end
        notify("Fly", "Disabled", THEME.RED)
        return
    end

    notify("Fly", "WASD to fly, hold Space=Up, Ctrl=Down", THEME.GREEN)

    local function startFly()
        local char = getChar()
        local root = getRoot()
        local hum  = getHum()
        if not char or not root or not hum then return end

        hum.PlatformStand = true

        flyBV = Instance.new("BodyVelocity", root)
        flyBV.Velocity       = Vector3.new(0,0,0)
        flyBV.MaxForce       = Vector3.new(math.huge, math.huge, math.huge)

        flyBG = Instance.new("BodyGyro", root)
        flyBG.MaxTorque      = Vector3.new(math.huge, math.huge, math.huge)
        flyBG.P              = 1e6
        flyBG.CFrame         = root.CFrame

        flyConn = RunService.RenderStepped:Connect(function()
            if not state.fly then return end
            local root2 = getRoot()
            if not root2 then return end

            local spd = state.flySpeed
            local vel = Vector3.new(0,0,0)
            local cf  = camera.CFrame

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                vel = vel + cf.LookVector * spd
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                vel = vel - cf.LookVector * spd
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                vel = vel - cf.RightVector * spd
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                vel = vel + cf.RightVector * spd
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                vel = vel + Vector3.new(0, spd, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                vel = vel - Vector3.new(0, spd, 0)
            end

            flyBV.Velocity = vel

            -- Keep upright, face camera direction on horizontal plane
            local lookAt = cf.LookVector
            local flatLook = Vector3.new(lookAt.X, 0, lookAt.Z)
            if flatLook.Magnitude > 0.01 then
                flyBG.CFrame = CFrame.new(root2.Position, root2.Position + flatLook)
            end
        end)
    end

    startFly()
    player.CharacterAdded:Connect(function()
        if state.fly then task.wait(0.3); startFly() end
    end)
end)

