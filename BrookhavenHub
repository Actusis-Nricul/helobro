-- Rainbow Character
local rainbowActive = false
makeToggle(miscPage, "Rainbow Character", function(on)
    rainbowActive = on
    if rainbowConn then rainbowConn:Disconnect(); rainbowConn = nil end
    if not on then
        -- Restore character colors
        local char = getChar()
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Color = Color3.fromRGB(163,162,165)
                end
            end
        end
        return
    end
    rainbowConn = RunService.Heartbeat:Connect(function()
        if not rainbowActive then rainbowConn:Disconnect(); return end
        local h = tick() % 1
        local char = getChar()
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Color = Color3.fromHSV(h, 1, 1)
            end
        end
    end)
    notify("Rainbow", "Your character is now rainbow 🌈", THEME.GREEN)
end)

