 -- remove death stuff
killBtn.MouseButton1Click:Connect(function()

	for _, obj in pairs(workspace:GetDescendants()) do
		local name = string.lower(obj.Name)

		-- 💀 LANDMINES
		if string.find(name, "landmine") then
			if obj:IsA("BasePart") then
				obj.CanTouch = false
				obj.Transparency = 0.7
			end
		end

		-- 🌪️ TORNADOS
		if string.find(name, "tornado") then
			if obj:IsA("BasePart") then
				obj.CanTouch = false
				obj.Transparency = 0.7
			end
		end

		-- 🌵 CACTUS DAMAGE
		if string.find(name, "cactus") or string.find(name, "stab") then
			if obj:IsA("BasePart") then
				obj.CanTouch = false
			end
		end

		-- 🏜️ QUICKSAND
		if string.find(name, "quicksand") then
			if obj:IsA("BasePart") then
				obj.CanCollide = true
				obj.CanTouch = false
				obj.Transparency = 0.5
			end
		end

		-- 💥 EXPLOSIONS
		if obj:IsA("Explosion") then
			obj:Destroy()
		end

		-- 🔥 FIRE / PARTICLES
		if obj:IsA("Fire") then
			obj:Destroy()
		end

		-- 💀 GENERIC DAMAGE PARTS
		if obj:IsA("BasePart") then
			if string.find(name, "kill")
			or string.find(name, "lava")
			or string.find(name, "damage")
			or string.find(name, "spike")
			or string.find(name, "trap") then
				
				obj.CanTouch = false
				obj.Transparency = 0.6
			end
		end

		-- 🧠 DISABLE TOUCH SCRIPTS
		if obj:IsA("Script") then
			local parent = obj.Parent
			if parent and parent:IsA("BasePart") then
				obj.Disabled = true
			end
		end

		-- ❌ REMOVE TOUCHINTEREST (VERY IMPORTANT)
		if obj:IsA("TouchTransmitter") then
			obj:Destroy()
		end

	end

	print("💀 ALL death sources removed (landmines, tornados, cactus, quicksand 😈)")

end)

