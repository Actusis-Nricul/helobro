-- 🧠 PROMPTS
local function getPrompts()
	local list = {}
	for _, v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") then
			table.insert(list, v)
		end
	end
	return list
end

local function getPromptName(prompt)
	if prompt.ActionText and prompt.ActionText ~= "" then
		return prompt.ActionText
	elseif prompt.ObjectText and prompt.ObjectText ~= "" then
		return prompt.ObjectText
	elseif prompt.Parent then
		return prompt.Parent.Name
	end
	return "Interaction"
end

