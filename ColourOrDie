--// TELEPORT
local function teleport(obj)
	if not obj then return end
	
	if obj:IsA("BasePart") then
		HRP.CFrame = obj.CFrame + Vector3.new(0,3,0)
	elseif obj:IsA("Model") then
		local part = obj:FindFirstChildWhichIsA("BasePart")
		if part then
			HRP.CFrame = part.CFrame + Vector3.new(0,3,0)
		end
	end
end

--// SPAM E
local function spamE()
	local start = tick()
	while tick() - start < 1 do
		VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
		task.wait(0.05)
		VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
		task.wait(0.05)
	end
end

local function tpAndCollect(obj)
	teleport(obj)
	task.wait(0.2)
	spamE()
end

--// DROPDOWN
local function createDropdown(title)
	local Container = Instance.new("Frame")
	Container.Size = UDim2.new(1,0,0,30)
	Container.BackgroundTransparency = 1
	Container.Parent = MainScroll
	
	local Button = Instance.new("TextButton")
	Button.Size = UDim2.new(1,0,0,30)
	Button.Text = title
	Button.BackgroundColor3 = Color3.fromRGB(40,40,40)
	Button.TextColor3 = Color3.new(1,1,1)
	Button.Parent = Container
	
	local List = Instance.new("Frame")
	List.Size = UDim2.new(1,0,0,0)
	List.Position = UDim2.new(0,0,0,30)
	List.BackgroundTransparency = 1
	List.Visible = false
	List.Parent = Container
	
	local Layout = Instance.new("UIListLayout", List)
	Layout.Padding = UDim.new(0,5)
	
	local function updateSize()
		if List.Visible then
			local size = Layout.AbsoluteContentSize.Y
			List.Size = UDim2.new(1,0,0,size)
			Container.Size = UDim2.new(1,0,0,30 + size)
		else
			List.Size = UDim2.new(1,0,0,0)
			Container.Size = UDim2.new(1,0,0,30)
		end
	end
	
	Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateSize)
	
	Button.MouseButton1Click:Connect(function()
		List.Visible = not List.Visible
		updateSize()
	end)
	
	return List
end

--// BUTTON
local function addButton(parent, text, obj)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1,0,0,30)
	btn.Text = text
	btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Parent = parent
	
	btn.MouseButton1Click:Connect(function()
		tpAndCollect(obj)
	end)
end

