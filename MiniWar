-- WIDGET FACTORIES
-- =====================
local BASE  = Color3.fromRGB(22, 22, 34)
local HOVER = Color3.fromRGB(34, 34, 52)
local ON    = Color3.fromRGB(28, 90, 50)
local toggleStates = {}

local function createSection(text)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -16, 0, 18)
    lbl.BackgroundTransparency = 1
    lbl.Text = "  " .. text:upper()
    lbl.TextColor3 = Color3.fromRGB(140, 80, 255)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 9
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = scroll
    return lbl
end

local function createToggle(label, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -16, 0, 36)
    btn.BackgroundColor3 = BASE
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Parent = scroll
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 8, 0, 8)
    dot.Position = UDim2.new(0, 10, 0.5, -4)
    dot.BackgroundColor3 = Color3.fromRGB(70, 70, 100)
    dot.BorderSizePixel = 0
    dot.Parent = btn
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -28, 1, 0)
    lbl.Position = UDim2.new(0, 24, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(200, 200, 220)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = btn

    -- pill switch
    local pill = Instance.new("Frame")
    pill.Size = UDim2.new(0, 32, 0, 14)
    pill.Position = UDim2.new(1, -42, 0.5, -7)
    pill.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    pill.BorderSizePixel = 0
    pill.Parent = btn
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 10, 0, 10)
    knob.Position = UDim2.new(0, 2, 0.5, -5)
    knob.BackgroundColor3 = Color3.fromRGB(120, 120, 150)
    knob.BorderSizePixel = 0
    knob.ZIndex = 2
    knob.Parent = pill
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    toggleStates[label] = false

    btn.MouseButton1Click:Connect(function()
        toggleStates[label] = not toggleStates[label]
        local on = toggleStates[label]
        btn.BackgroundColor3 = on and ON or BASE
        dot.BackgroundColor3 = on and Color3.fromRGB(80, 255, 130) or Color3.fromRGB(70, 70, 100)
        lbl.TextColor3 = on and Color3.new(1,1,1) or Color3.fromRGB(200, 200, 220)
        pill.BackgroundColor3 = on and Color3.fromRGB(100, 50, 200) or Color3.fromRGB(50, 50, 70)
        knob.BackgroundColor3 = on and Color3.new(1,1,1) or Color3.fromRGB(120, 120, 150)
        knob.Position = on and UDim2.new(1,-12,0.5,-5) or UDim2.new(0,2,0.5,-5)
        callback(on)
    end)
    btn.MouseEnter:Connect(function()
        if not toggleStates[label] then btn.BackgroundColor3 = HOVER end
    end)
    btn.MouseLeave:Connect(function()
        if not toggleStates[label] then btn.BackgroundColor3 = BASE end
    end)
    return btn
end

local function createButton(label, color, callback)
    color = color or BASE
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -16, 0, 36)
    btn.BackgroundColor3 = color
    btn.Text = label
    btn.TextColor3 = Color3.fromRGB(220, 220, 240)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Parent = scroll
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    btn.MouseButton1Click:Connect(callback)
    btn.MouseEnter:Connect(function() btn.BackgroundColor3 = HOVER end)
    btn.MouseLeave:Connect(function() btn.BackgroundColor3 = color end)
    return btn
end

