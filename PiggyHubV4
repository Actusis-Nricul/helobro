	Callback = function(Value)

		if Value then

			PingGui = Instance.new("ScreenGui")
			PingGui.Parent = game.CoreGui

			local Label = Instance.new("TextLabel")
			Label.Parent = PingGui
			Label.Size = UDim2.new(0, 150, 0, 30)
			Label.Position = UDim2.new(0, 10, 0, 45)
			Label.BackgroundColor3 = Color3.fromRGB(25,25,25)
			Label.TextColor3 = Color3.new(1,1,1)

			task.spawn(function()
				while PingGui and task.wait(1) do
					local Success, Ping = pcall(function()
						return math.floor(
							Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
						)
					end)

					if Success then
						Label.Text = "Ping: "..Ping.." ms"
					else
						Label.Text = "Ping: N/A"
					end
				end
			end)

		else

			if PingGui then
				PingGui:Destroy()
				PingGui = nil
			end

		end
	end,
})

