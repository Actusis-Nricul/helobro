local Toggle = MapTab:CreateToggle({
   Name = "VSync (Check Console If not Working)",
   CurrentValue = false,
   Flag = "VSYNCTOGGLE2026PIGGY",

   Callback = function(Value)

      local funcs = {
         "setvsync",
         "set_vsync",
         "setfpsvsync",
         "vsync",
         "setVSync",
         "SetVSync"
      }

      local worked = false

      for _, funcName in ipairs(funcs) do
         local func = getgenv()[funcName] or getrenv()[funcName]

         if typeof(func) == "function" then
            pcall(function()
               func(Value)
            end)

            worked = true
         end
      end

      if worked then
         print("Attempted to set VSync:", Value)
      else
         warn("No supported VSync function found.")
      end
   end,
})
