---------------------------------------------------
-- NUMBER PARSER
---------------------------------------------------

local function parseNumber(text)

	text = string.lower(text)

	local multipliers = {
		k = 1e3,
		m = 1e6,
		b = 1e9,
		t = 1e12
	}

	local suffix = string.sub(text,-1)
	local number = tonumber(text)

	-- normal number
	if number then
		return number
	end

	-- shortened number
	local base = tonumber(string.sub(text,1,#text-1))

	if base and multipliers[suffix] then
		return base * multipliers[suffix]
	end

	return nil
end

