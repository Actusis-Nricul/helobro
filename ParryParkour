local platformBtn = makeButton("Head Platform: OFF", 50)

local function createPlatform()

	if platformPart then
		platformPart:Destroy()
	end

	local char = player.Character
	if not char then return end

	local head = char:FindFirstChild("Head")
	if not head then return end

	platformPart = Instance.new("Part")
	platformPart.Name = "SecretPlatform"

	platformPart.Size = Vector3.new(14,1,14)

	platformPart.Material = Enum.Material.SmoothPlastic
	platformPart.Color = Color3.fromRGB(120,120,120)

	platformPart.Transparency = 0
	platformPart.CanCollide = true
	platformPart.Anchored = false

	platformPart.Parent = workspace

	-- keep tightly attached to head
	local weld = Instance.new("WeldConstraint")
	weld.Part0 = head
	weld.Part1 = platformPart
	weld.Parent = platformPart

	platformPart.Position = head.Position + Vector3.new(0,0.8,0)
end

platformBtn.MouseButton1Click:Connect(function()

	platformEnabled = not platformEnabled

	if platformEnabled then
		platformBtn.Text = "Head Platform: ON"
		createPlatform()
	else
		platformBtn.Text = "Head Platform: OFF"

		if platformPart then
			platformPart:Destroy()
			platformPart = nil
		end
	end
end)

---------------------------------------------------
-- PLATFORM HIT DETECTION
---------------------------------------------------

RunService.RenderStepped:Connect(function()

	if platformEnabled and platformPart and player.Character and not platformCooldown then

		local hrp = player.Character:FindFirstChild("HumanoidRootPart")

		if hrp then

			local speed = hrp.AssemblyLinearVelocity.Magnitude

			-- huge push detected
			if speed > 90 then

				platformCooldown = true

				platformPart:Destroy()
				platformPart = nil

				-- comes back after 2 seconds
				task.delay(2,function()

					if platformEnabled then
						createPlatform()
					end

					platformCooldown = false
				end)
			end
		end
	end
end)

