local corners = {}

local function registerCorner(inst)
	table.insert(corners, inst)
	return inst
end

local function applyCorners(radius)
	for _,c in ipairs(corners) do
		if c and c.Parent then
			c.CornerRadius = UDim.new(0, radius)
		end
	end
end

local esp = false
local espOutline = Color3.fromRGB(255,255,255)
local espFill = Color3.fromRGB(255,0,0)

local function updateESP()
	for _,plr in pairs(game.Players:GetPlayers()) do
		if plr ~= player and plr.Character then
			local char = plr.Character
			local highlight = char:FindFirstChild("Highlight")

			if esp then
				if not highlight then
					highlight = Instance.new("Highlight")
					highlight.Name = "Highlight"
					highlight.Parent = char
				end

				highlight.FillColor = espFill
				highlight.OutlineColor = espOutline
				highlight.FillTransparency = 0.5
			else
				if highlight then
					highlight:Destroy()
				end
			end
		end
	end
end

task.spawn(function()
	while true do
		if esp then
