local cloning = false
local clones = {}

local cloneCountBox = box(scripts,600,"Clone Amount")
local spacingBox = box(scripts,640,"Spacing (studs)")

local function clearClones()
	for _,c in ipairs(clones) do
		c:Destroy()
	end
	clones = {}
end

btn(scripts,"Toggle Local Clones",680).MouseButton1Click:Connect(function()
	cloning = not cloning

	if not cloning then
		clearClones()
		return
	end

	clearClones()

	local count = math.clamp(parseNumber(cloneCountBox.Text),1,20)
	local spacing = parseNumber(spacingBox.Text)
	if spacing <= 0 then spacing = 5 end

	local char = player.Character
	if not char then return end

	for i = 1, count do
		local clone = char:Clone()

		-- remove scripts so it doesn't break
		for _,v in ipairs(clone:GetDescendants()) do
			if v:IsA("Script") or v:IsA("LocalScript") then
				v:Destroy()
			end
		end

		clone.Parent = workspace

		-- make it stable + climbable
		for _,part in ipairs(clone:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Anchored = true
				part.CanCollide = true
			end
		end

		table.insert(clones, clone)
	end
end)

-- POSITION THEM (circle around you)
RunService.RenderStepped:Connect(function()
	if not cloning then return end

	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	local count = #clones
	local spacing = parseNumber(spacingBox.Text)
	if spacing <= 0 then spacing = 5 end

	for i,clone in ipairs(clones) do
		local cHRP = clone:FindFirstChild("HumanoidRootPart")
		if cHRP then
			local angle = (i / count) * math.pi * 2
			local offset = Vector3.new(
				math.cos(angle) * spacing,
				0,
				math.sin(angle) * spacing
			)

			cHRP.CFrame = CFrame.new(hrp.Position + offset)
		end
	end
end)

