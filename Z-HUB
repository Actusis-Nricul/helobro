-- Resize handles
local function resizeHandle(size,pos,mode)
	local h = Instance.new("Frame")
	h.Size = size
	h.Position = pos
	h.BackgroundTransparency = 1
	h.Parent = main

	h.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			local start = UIS:GetMouseLocation()
			local startSize = main.Size

			local move, up
			move = UIS.InputChanged:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseMovement then
					local delta = UIS:GetMouseLocation() - start

					main.Size = UDim2.new(
						0,
						startSize.X.Offset + (mode=="x" or mode=="xy" and delta.X or 0),
						0,
						startSize.Y.Offset + (mode=="y" or mode=="xy" and delta.Y or 0)
					)
				end
			end)

			up = UIS.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 then
					move:Disconnect()
					up:Disconnect()
				end
			end)
		end
	end)
end

