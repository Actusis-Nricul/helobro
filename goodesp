-- === ESP SYSTEM ===
local ESP_ON = false
local FRIENDS_ONLY = false
local Cache = {}

local function removeESP(plr)
	if Cache[plr] then
		for _, v in pairs(Cache[plr]) do
			if v then v:Destroy() end
		end
		Cache[plr] = nil
	end
end

local function createESP(plr)
	if not plr.Character or not plr.Character:FindFirstChild("Head") then return end
	if Cache[plr] then return end

	local char = plr.Character

	local hl = Instance.new("Highlight")
	hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	hl.FillTransparency = 0.5
	hl.OutlineColor = Color3.new(1,1,1)
	hl.Parent = char

	local bill = Instance.new("BillboardGui")
	bill.Size = UDim2.new(0,100,0,30)
	bill.AlwaysOnTop = true
	bill.StudsOffset = Vector3.new(0,2,0)
	bill.Parent = char.Head

	local text = Instance.new("TextLabel")
	text.Size = UDim2.new(1,0,1,0)
	text.BackgroundTransparency = 1
	text.TextScaled = true
	text.Font = Enum.Font.SourceSansBold
	text.TextColor3 = Color3.new(1,1,1)
	text.TextStrokeTransparency = 0
	text.Text = plr.Name
	text.Parent = bill

	Cache[plr] = {hl, bill}
end

local function clearAll()
	for plr,_ in pairs(Cache) do
		removeESP(plr)
	end
end

-- === LOOP (EVERY FRAME) ===
RunService.RenderStepped:Connect(function()
	if not ESP_ON then return end

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer then
			
			if FRIENDS_ONLY and not LocalPlayer:IsFriendsWith(plr.UserId) then
				removeESP(plr)
				continue
			end

			if plr.Character and plr.Character:FindFirstChild("Head") then
				createESP(plr)

				local hl = Cache[plr] and Cache[plr][1]
				if hl then
					hl.FillColor = FRIENDS_ONLY and Color3.fromRGB(0,255,100) or Color3.fromRGB(255,0,0)
				end
			else
				removeESP(plr)
			end
		end
	end
end)

-- === BUTTON LOGIC ===
ESPBtn.MouseButton1Click:Connect(function()
	ESP_ON = not ESP_ON
	FRIENDS_ONLY = false

	ESPBtn.Text = ESP_ON and "ESP: ON" or "ESP: OFF"

	if not ESP_ON then
		clearAll()
	end
end)

FriendBtn.MouseButton1Click:Connect(function()
	ESP_ON = not ESP_ON
	FRIENDS_ONLY = true

	FriendBtn.Text = ESP_ON and "FRIENDS ESP: ON" or "FRIENDS ESP: OFF"

	if not ESP_ON then
		clearAll()
	end
end)
