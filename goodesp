local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

-- ESP settings
local FILL_COLOR = Color3.fromRGB(255, 0, 0)
local OUTLINE_COLOR = Color3.fromRGB(255, 0, 0)
local FILL_TRANSPARENCY = 0.5
local OUTLINE_TRANSPARENCY = 0
local MAX_DISTANCE = math.huge -- show at any distance

-- Store ESP objects
local ESPObjects = {}

-- Create BillboardGui text
local function createBillboard(character)
    local head = character:FindFirstChild("Head")
    if not head then return nil end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESPBillboard"
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = MAX_DISTANCE
    billboard.ResetOnSpawn = false

    local label = Instance.new("TextLabel")
    label.Name = "Info"
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.new(0, 0, 0)
    label.Font = Enum.Font.SourceSansBold
    label.TextScaled = true
    label.RichText = false
    label.Parent = billboard

    billboard.Parent = head
    return billboard
end

-- Create Highlight
local function createHighlight(character)
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESPHighlight"
    highlight.Adornee = character
    highlight.FillColor = FILL_COLOR
    highlight.OutlineColor = OUTLINE_COLOR
    highlight.FillTransparency = FILL_TRANSPARENCY
    highlight.OutlineTransparency = OUTLINE_TRANSPARENCY
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- through walls
    highlight.Parent = character

    return highlight
end

-- Remove ESP from a player
local function removeESP(player)
    local data = ESPObjects[player]
    if data then
        if data.connection then
            data.connection:Disconnect()
        end
        if data.highlight and data.highlight.Parent then
            data.highlight:Destroy()
        end
        if data.billboard and data.billboard.Parent then
            data.billboard:Destroy()
        end
        ESPObjects[player] = nil
    end
end

-- Create ESP for a player
local function setupESP(player)
    if player == LocalPlayer then return end

    local function onCharacter(character)
        removeESP(player)

        local humanoid = character:WaitForChild("Humanoid", 5)
        local root = character:WaitForChild("HumanoidRootPart", 5)
        local localChar = LocalPlayer.Character
        if not humanoid or not root then return end

        local highlight = createHighlight(character)
        local billboard = createBillboard(character)
        if not billboard then
            highlight:Destroy()
            return
        end

        local label = billboard:FindFirstChild("Info")

        local connection
        connection = RunService.RenderStepped:Connect(function()
            -- Stop if objects are gone
            if not player.Parent or not character.Parent then
                removeESP(player)
                return
            end

            local localCharacter = LocalPlayer.Character
            local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")

            if not localRoot then
                return
            end

            -- Distance in studs
            local distance = (localRoot.Position - root.Position).Magnitude
            if distance > MAX_DISTANCE then
                billboard.Enabled = false
                highlight.Enabled = false
                return
            end

            billboard.Enabled = true
            highlight.Enabled = true

            -- Health as percentage (0-100)
            local healthPercent = 0
            if humanoid.MaxHealth > 0 then
                healthPercent = math.floor((humanoid.Health / humanoid.MaxHealth) * 100 + 0.5)
            end

            label.Text = string.format(
                "%s\nHP: %d%% | %d studs",
                player.Name,
                healthPercent,
                math.floor(distance)
            )
        end)

        ESPObjects[player] = {
            highlight = highlight,
            billboard = billboard,
            connection = connection
        }
    end

    -- Current character
    if player.Character then
        task.spawn(onCharacter, player.Character)
    end

    -- Respawns
    player.CharacterAdded:Connect(onCharacter)
    player.CharacterRemoving:Connect(function()
        removeESP(player)
    end)
end

-- Setup existing players
for _, player in ipairs(Players:GetPlayers()) do
    setupESP(player)
end

-- Detect new players
Players.PlayerAdded:Connect(setupESP)

-- Detect leaving players
Players.PlayerRemoving:Connect(removeESP)
